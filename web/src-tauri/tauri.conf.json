{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-nightly/dev/crates/tauri-config-schema/schema.json",
  "productName": "clipmatic.video",
  "version": "0.1.0",
  "identifier": "com.clipmatic.video",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "clipmatic.video",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "externalBin": [
      "binaries/python-backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
